# ─────────────────────────────────────────────
#  Change LOGIN to your 42 login before running
# ─────────────────────────────────────────────
LOGIN = "alrahmou"

Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"
  config.vm.box_check_update = false
  # Disable the default synced folder for faster startup on Linux hosts
  # (uncomment or change to `type: "nfs"` if you need host<->guest sharing)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ── Server (controller) ──────────────────────
  config.vm.define "#{LOGIN}S" do |server|
    server.vm.hostname = "#{LOGIN}S"
    server.vm.network "private_network",
      ip: "192.168.56.110",
      libvirt__network_name: "p1",
      libvirt__dhcp_enabled: false

    server.vm.provider "virtualbox" do |v|
      v.name   = "#{LOGIN}S"
      v.memory = 1024
      v.cpus   = 1
    end

    server.vm.provider "libvirt" do |v|
      v.cpus   = 1
      v.memory = 1024
    end

    server.vm.provision "shell", inline: <<-SHELL
      set -e
      echo "[network] Waiting for 192.168.56.110..."
      for i in $(seq 1 60); do
        if ip -o -4 addr show | grep -q '192.168.56.110/'; then
          ip -o -4 addr show | grep '192.168.56.110/'
          exit 0
        fi
        sleep 2
      done
      echo "[network] ERROR: 192.168.56.110 not configured after 120s" >&2
      ip -o -4 addr show >&2
      exit 1
    SHELL

    server.vm.provision "shell", path: "scripts/server.sh"
  end

  # ── Worker (agent) ───────────────────────────
  config.vm.define "#{LOGIN}SW" do |worker|
    worker.vm.hostname = "#{LOGIN}SW"
    worker.vm.network "private_network",
      ip: "192.168.56.111",
      libvirt__network_name: "p1",
      libvirt__dhcp_enabled: false

    worker.vm.provider "virtualbox" do |v|
      v.name   = "#{LOGIN}SW"
      v.memory = 1024
      v.cpus   = 1
    end

    worker.vm.provider "libvirt" do |v|
      v.cpus   = 1
      v.memory = 1024
    end

    worker.vm.provision "shell", inline: <<-SHELL
      set -e
      echo "[network] Waiting for 192.168.56.111..."
      for i in $(seq 1 60); do
        if ip -o -4 addr show | grep -q '192.168.56.111/'; then
          ip -o -4 addr show | grep '192.168.56.111/'
          exit 0
        fi
        sleep 2
      done
      echo "[network] ERROR: 192.168.56.111 not configured after 120s" >&2
      ip -o -4 addr show >&2
      exit 1
    SHELL

    worker.vm.provision "shell", path: "scripts/worker.sh"
  end
end
