Vagrant.configure("2") do |config|
  # Latest stable Ubuntu LTS
  config.vm.box = "generic/ubuntu2204"

  # Minimal resources (1 CPU, 1024 MB) as advised
  config.vm.provider :libvirt do |v|
    v.cpus = 1
    v.memory = 1024
  end

  # Server VM: <login>S → alrahmouS
  config.vm.define "alrahmouS" do |srv|
    srv.vm.hostname = "alrahmouS"
    srv.vm.network "private_network",
      ip: "192.168.56.110",
      libvirt__dhcp_enabled: false

    srv.vm.provision "shell", path: "scripts/server.sh"
  end

  # ServerWorker VM: <login>SW → alrahmouSW
  config.vm.define "alrahmouSW" do |w|
    w.vm.hostname = "alrahmouSW"
    w.vm.network "private_network",
      ip: "192.168.56.111",
      libvirt__dhcp_enabled: false

    w.vm.provision "shell", path: "scripts/worker.sh"
  end
end
